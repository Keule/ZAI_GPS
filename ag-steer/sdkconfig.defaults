# sdkconfig.defaults for LilyGO T-ETH-Lite-S3
# ESP32-S3-WROOM-1-N8R8: 16 MB Flash, 8 MB Octal PSRAM
#
# These settings are merged into the sdkconfig at build time.
# PlatformIO picks up this file automatically.

# === PSRAM: DISABLED ===
# We don't need PSRAM for AgSteer (firmware is small, no large buffers).
# Disabling avoids PSRAM init errors that crash the ESP32-S3 during boot.
# The T-ETH-Lite-S3 has Octal PSRAM on board but we explicitly disable it.
CONFIG_SPIRAM=n

# === Flash & App Settings ===
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# === FreeRTOS ===
CONFIG_FREERTOS_HZ=1000

# === Logging ===
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y
